{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://localhost/index.html",
        "http://localhost/divisions/neurology/index.html",
        "http://localhost/divisions/critical-care/index.html",
        "http://localhost/blog/tbi-litigation-neurology-expert-witness/index.html",
        "http://localhost/blog/index.html",
        "http://localhost/experts/index.html",
        "http://localhost/experts/abhi-kapuria/index.html"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "skipAudits": ["uses-http2"]
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.9 }],

        "csp-xss": "off",
        "deprecations": "off",
        "errors-in-console": "off",
        "is-on-https": "off",
        "redirects-http": "off",
        "uses-http2": "off",
        "valid-source-maps": "off",
        "unused-javascript": "warn",
        "unused-css-rules": "warn",
        "render-blocking-resources": "warn"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
